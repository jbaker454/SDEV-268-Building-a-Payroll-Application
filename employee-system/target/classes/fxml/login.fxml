<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jbaker454.LoginController"
      spacing="10" alignment="CENTER" prefWidth="300" prefHeight="200">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Employee System Login" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="Username:"/>
        <TextField fx:id="usernameField" promptText="Enter username"/>
    </VBox>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="Password:"/>
        <PasswordField fx:id="passwordField" promptText="Enter password"/>
    </VBox>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="Role:"/>
        <ComboBox fx:id="roleComboBox" promptText="Select role">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="EMPLOYEE"/>
                    <String fx:value="HR"/>
                    <String fx:value="ADMIN"/>
                </FXCollections>
            </items>
        </ComboBox>
    </VBox>

    <Button text="Login" onAction="#handleLogin" prefWidth="100"/>

    <Label fx:id="errorLabel" textFill="RED"/>
</VBox>