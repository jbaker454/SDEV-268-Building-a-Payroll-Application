<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>

<BorderPane prefHeight="800.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jbaker454.HRViewController">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #1f3a93; -fx-padding: 12;">
      <children>
        <Label text="HR Dashboard - Employee Management" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
      </children>
    </HBox>
  </top>
  <center>
    <VBox spacing="12.0" style="-fx-padding: 15;">
      <children>
        <!-- Search Panel -->
        <HBox spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 10; -fx-background-color: #f9f9f9;">
          <children>
            <Label text="Search:" style="-fx-font-weight: bold;" />
            <TextField fx:id="searchField" prefWidth="200.0" promptText="Enter search term..." />
            <ComboBox fx:id="searchTypeCombo" prefWidth="100.0" />
            <Button fx:id="searchButton" mnemonicParsing="false" onAction="#handleSearch" text="Search" style="-fx-padding: 5 15 5 15;" />
            <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleRefresh" text="Clear" style="-fx-padding: 5 15 5 15;" />
          </children>
        </HBox>

        <!-- Employee Table -->
        <Label text="Employee List" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
        <TableView fx:id="employeeTable" prefHeight="250.0" prefWidth="970.0" VBox.vgrow="NEVER">
          <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="250.0" />
            <TableColumn fx:id="departmentColumn" text="Department" prefWidth="200.0" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="150.0" />
          </columns>
        </TableView>

        <!-- Employee Management Buttons -->
        <HBox spacing="10.0" alignment="CENTER_LEFT">
          <children>
            <Button fx:id="viewDetailsButton" mnemonicParsing="false" onAction="#handleViewDetails" text="View Details" style="-fx-padding: 5 15 5 15;" />
            <Button fx:id="addEmployeeButton" mnemonicParsing="false" onAction="#handleAddEmployee" text="Add Employee" style="-fx-padding: 5 15 5 15; -fx-font-weight: bold;" />
            <Button fx:id="editEmployeeButton" mnemonicParsing="false" onAction="#handleEditEmployee" text="Edit Employee" style="-fx-padding: 5 15 5 15;" />
            <Button fx:id="generateReportButton" mnemonicParsing="false" onAction="#handleGenerateReport" text="Generate Payroll Report" style="-fx-padding: 5 15 5 15; -fx-font-weight: bold;" />
          </children>
        </HBox>

        <!-- Employee Details -->
        <Label text="Employee Details" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
        <TextArea fx:id="detailsArea" prefHeight="200.0" prefWidth="970.0" wrapText="true" editable="false" VBox.vgrow="ALWAYS" />
      </children>
    </VBox>
  </center>
</BorderPane>
