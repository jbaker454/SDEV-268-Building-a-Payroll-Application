<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jbaker454.EmployeeViewController">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #34495e; -fx-padding: 12;">
      <children>
        <Label text="Employee View" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
      </children>
    </HBox>
  </top>
  <center>
    <VBox alignment="TOP_CENTER" spacing="14.0" style="-fx-padding: 20;">
      <children>
        <Label fx:id="welcomeLabel" text="Welcome back! Here is your daily summary." />
        <TextArea fx:id="statusTextArea" editable="false" wrapText="true" prefHeight="220.0" prefWidth="520.0" />
        <HBox alignment="CENTER" spacing="10.0">
          <children>
            <Button fx:id="viewProfileButton" mnemonicParsing="false" text="View Profile" onAction="#handleViewProfile" />
            <Button mnemonicParsing="false" text="View Schedule" onAction="#handleViewSchedule" />
            <Button fx:id="clockInButton" mnemonicParsing="false" disable="true" text="Clock In" onAction="#handleClockIn" />
            <Button fx:id="clockOutButton" mnemonicParsing="false" disable="true" text="Clock Out" onAction="#handleClockOut" />
            <Button mnemonicParsing="false" text="Calculate Pay" onAction="#handleCalculatePay" />
          </children>
        </HBox>
      </children>
    </VBox>
  </center>
</BorderPane>
