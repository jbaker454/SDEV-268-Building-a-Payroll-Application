<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="300.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jbaker454.LoginController">
   <children>
      <Pane prefHeight="300.0" prefWidth="500.0">
         <children>
            <VBox layoutX="111.0" layoutY="38.0" prefHeight="271.0" prefWidth="279.0">
               <children>
                  <HBox prefHeight="56.0" prefWidth="279.0">
                     <children>
                        <Label id="LoginUserName" prefHeight="25.0" prefWidth="80.0" text="Username:" />
                        <TextField fx:id="usernameField" />
                     </children>
                  </HBox>
                  <HBox prefHeight="51.0" prefWidth="279.0">
                     <children>
                        <Label prefHeight="25.0" prefWidth="80.0" text="Password:" />
                        <PasswordField fx:id="passwordField" />
                     </children>
                  </HBox>
                  <Label fx:id="errorLabel" layoutX="111.0" layoutY="190.0" textFill="RED" wrapText="true" />
               </children>
            </VBox>
            <Button layoutX="363.0" layoutY="220.0" mnemonicParsing="false" onAction="#handleLogin" text="Login" />
         </children>
      </Pane>
   </children>
</VBox>
