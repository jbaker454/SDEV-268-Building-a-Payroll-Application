<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="420.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #1f3a93; -fx-padding: 12;">
      <children>
        <Label text="HR Dashboard" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
      </children>
    </HBox>
  </top>
  <center>
    <VBox alignment="TOP_CENTER" spacing="14.0" style="-fx-padding: 18;">
      <children>
        <TableView prefHeight="280.0" prefWidth="660.0">
          <columns>
            <TableColumn text="Employee" prefWidth="180.0" />
            <TableColumn text="Department" prefWidth="160.0" />
            <TableColumn text="Status" prefWidth="160.0" />
            <TableColumn text="Last Review" prefWidth="160.0" />
          </columns>
        </TableView>
        <HBox alignment="CENTER" spacing="12.0">
          <children>
            <Button mnemonicParsing="false" text="Manage Benefits" />
            <Button mnemonicParsing="false" text="Approve Time Off" />
            <Button mnemonicParsing="false" text="Run HR Report" />
          </children>
        </HBox>
      </children>
    </VBox>
  </center>
</BorderPane>
